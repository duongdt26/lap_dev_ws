<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1"/> 
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/> 
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/> 
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/> 
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/> 
    </material>

    <material name="green">
        <color rgba="0 1 0 1"/> 
    </material>

    <material name="vibrantorange">
        <color rgba="1.0 0.5 0 1"/>
    </material>

    <material name="xanhlo">
        <color rgba="0.18 0.85 0.8 1"/>
    </material>

    <material name="xanhdaquang">
        <color rgba="0.4 0.91 0.22 1"/>
    </material>

    <material name="tim">
        <color rgba="0.62 0.22 0.9 1"/>
    </material>    

    
    <!-- BASE FOOTPRINT -->
    
    <link name="base_footprint">

    </link>


    <!-- BASE LINK -->

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.09" rpy="0 0 0"/>
    </joint>
    
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.075"/>
            <geometry>
                <box size="1.170 0.665 0.3"/>
                <!-- <box size="1.0 0.6 0.4"/> -->
                <!-- <mesh filename="package://amr_lan_2/meshes/base_link.STL"/> -->
            </geometry>
            <material name="xanhlo"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.075"/>
            <geometry>
                <box size="1.170 0.665 0.3"/>
                <!-- <box size="1.0 0.6 0.4"/> -->
                <!-- <mesh filename="package://amr_lan_2/meshes/base_link.STL"/> -->
            </geometry>
        </collision>
        
        <xacro:inertial_box mass="200" x="1.0" y="0.6" z="0.1">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="base_link">
        <material>Gazebo/Green</material>
    </gazebo>


    <!-- LEFT WHEEL LINK -->

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.28 0" rpy="-${pi/2} 0 0"/>
        <!-- <origin xyz="0 0.28 0" rpy="0 0 0"/> -->
        <axis xyz="0 0 1"/>
    </joint>
    
    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.09" length="0.05"/>
                <!-- <mesh filename="package://amr_lan_2/meshes/left_wheel.STL"/> -->
            </geometry>
            <material name="tim"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.09" length="0.05"/>
                <!-- <mesh filename="package://amr_lan_2/meshes/left_wheel.STL"/> -->
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass = "3" length="0.05" radius="0.09">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel">
        <material>Gazebo/Purple</material>
    </gazebo>


    <!-- RIGHT WHEEL LINK -->

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.28 0" rpy="${pi/2} 0 0"/>
        <!-- <origin xyz="0 0.28 0" rpy="0 0 0"/> -->
        <axis xyz="0 0 -1"/>
    </joint>
    
    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.09" length="0.05"/>
                <!-- <mesh filename="package://amr_lan_2/meshes/right_wheel.STL"/> -->
            </geometry>
            <material name="tim"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.09" length="0.05"/>
                <!-- <mesh filename="package://amr_lan_2/meshes/right_wheel.STL"/> -->
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass = "3" length="0.05" radius="0.09">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel">
        <material>Gazebo/Purple</material>
    </gazebo>


    <!-- CASTER WHEEL RIGHT BEHIND LINK -->

    <joint name="caster_wheel_right_behind_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_right_behind"/>
        <origin xyz="-0.4 -0.17 -0.075" rpy="0 0 0"/>
    </joint>
    
    <link name="caster_wheel_right_behind">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
                <!-- <mesh filename=
                "package://amr_lan_2/meshes/caster_wheel_right_behind.STL"/> -->
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
                <!-- <mesh filename=
                "package://amr_lan_2/meshes/caster_wheel_right_behind.STL"/> -->
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="0.5" radius="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_right_behind">
        <material>Gazebo/Blue</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>


    <!-- CASTER WHEEL LEFT BEHIND LINK -->

    <joint name="caster_wheel_left_behind_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_left_behind"/>
        <origin xyz="-0.4 0.17 -0.075" rpy="0 0 0"/>
    </joint>
    
    <link name="caster_wheel_left_behind">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
                <!-- <mesh filename=
                "package://amr_lan_2/meshes/caster_wheel_left_behind.STL"/> -->
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
                <!-- <mesh filename=
                "package://amr_lan_2/meshes/caster_wheel_left_behind.STL"/> -->
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="0.5" radius="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_left_behind">
        <material>Gazebo/Blue</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>



    <!-- CASTER WHEEL RIGHT FRONT LINK -->

    <joint name="caster_wheel_right_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_right_front"/>
        <origin xyz="0.4 0.17 -0.075" rpy="0 0 0"/>
    </joint>
    
    <link name="caster_wheel_right_front">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
                <!-- <mesh filename="package://amr_lan_2/meshes/caster_wheel_right_front.STL"/> -->
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
                <!-- <mesh filename=
                "package://amr_lan_2/meshes/caster_wheel_right_front.STL"/> -->
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="0.5" radius="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_right_front">
        <material>Gazebo/Blue</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>



    <!-- CASTER WHEEL LEFT FRONT LINK -->

    <joint name="caster_wheel_left_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_left_front"/>
        <origin xyz="0.4 -0.17 -0.075" rpy="0 0 0"/>
    </joint>
    
    <link name="caster_wheel_left_front">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
                <!-- <mesh filename="package://amr_lan_2/meshes/caster_wheel_left_front.STL"/> -->
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
                <!-- <mesh filename=
                "package://amr_lan_2/meshes/caster_wheel_left_front.STL"/> -->
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="0.5" radius="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_left_front">
        <material>Gazebo/Blue</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>



    <!-- LASER FRAME -->

    <joint name="laser_joint" type="fixed">
        <!-- <origin xyz="0.545 0.2925 0.283"
        rpy="0 0 3.1416" /> -->
        <origin xyz="0.545 0.2925 0.283" rpy="0 0 ${pi}" />
        <parent link="base_link" />
        <child link="laser_frame" />
        <axis xyz="0 0 0" />
    </joint>

    <link name="laser_frame">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.035" length="0.04"/>
                <!-- <mesh filename=
                "package://amr_lan_2/meshes/laser_frame.STL"/> -->
            </geometry>
            <material
                name="">
                <color
                rgba="0.211764705882353 0.211764705882353 0.203921568627451 1"/>
                <!-- <color name="xanhlo"/> -->
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.035" length="0.04"/>
                <!-- <mesh filename=
                "package://amr_lan_2/meshes/laser_frame.STL"/> -->
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.035">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
        <!-- <inertial> -->
        <!-- <origin
            xyz="0.00512745596438602 0.000556520497701551 -0.0195507847870177"
            rpy="0 0 0" /> -->
        <!-- <origin
            xyz="0.00512745596438602 0.000556520497701551 -0.0195507847870177"
            rpy="0 0 0" />
        <mass
            value="0.141654473640087" />
        <inertia
            ixx="0.01"
            ixy="0"
            ixz="0"
            iyy="0.01"
            iyz="0"
            izz="0.01" />
        </inertial> -->
    </link>


    

</robot>