<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1"/> 
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/> 
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/> 
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/> 
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/> 
    </material>

    <material name="green">
        <color rgba="0 1 0 1"/> 
    </material>

    <material name="vibrantorange">
        <color rgba="1.0 0.5 0 1"/>
    </material>

    <material name="xanhlo">
        <color rgba="0.18 0.85 0.8 1"/>
    </material>

    <material name="xanhdaquang">
        <color rgba="0.4 0.91 0.22 1"/>
    </material>

    <material name="tim">
        <color rgba="0.62 0.22 0.9 1"/>
    </material>    

    
    <!-- BASE FOOTPRINT -->
    
    <link name="base_footprint">

    </link>


    <!-- BASE LINK -->

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.09" rpy="0 0 0"/>
    </joint>
    
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <box size="1.170 0.665 0.15"/>
            </geometry>
            <material name="xanhlo"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <box size="1.170 0.665 0.15"/>
            </geometry>
        </collision>
        
        <xacro:inertial_box mass="180" x="1.17" y="0.665" z="0.15">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- <gazebo reference="base_link">
        <material>Gazebo/Green</material>
    </gazebo> -->


     <!-- CHASSIS 1 LINK -->

    <joint name="chassis_1_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis_1_link"/>
        <origin xyz="0 0 0.105" rpy="0 0 0"/>
    </joint>
    
    <link name="chassis_1_link">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <box size="1.0 0.5 0.06"/>
            </geometry>
            <material name="vibrantorange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <box size="1.0 0.5 0.06"/>
            </geometry>
        </collision>
        
        <xacro:inertial_box mass="2" x="1.0" y="0.5" z="0.06">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- <gazebo reference="base_link">
        <material>Gazebo/Green</material>
    </gazebo> -->



    <!-- LEFT WHEEL LINK -->

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.28 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>
    
    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.09" length="0.04"/>
            </geometry>
            <material name="tim"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.09" length="0.04"/>
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass = "1.5" length="0.04" radius="0.09">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- <gazebo reference="left_wheel">
        <material>Gazebo/Purple</material>
        <mu1 value="0.4"/>
        <mu2 value="0.4"/>
    </gazebo> -->


    <!-- RIGHT WHEEL LINK -->

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.28 0" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>
    
    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.09" length="0.04"/>
            </geometry>
            <material name="tim"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.09" length="0.04"/>
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass = "1.5" length="0.04" radius="0.09">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- <gazebo reference="right_wheel">
        <material>Gazebo/Purple</material>
        <mu1 value="0.4"/>
        <mu2 value="0.4"/>
    </gazebo> -->



       
    <!-- CASTER WHEEL RIGHT BEHIND LINK -->

    <joint name="caster_wheel_right_behind_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_right_behind"/>
        <origin xyz="-0.4 -0.17 -0.0749" rpy="0 0 0"/>
    </joint>
    
    <link name="caster_wheel_right_behind">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="1" radius="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <!-- <gazebo reference="caster_wheel_right_behind">
        <material>Gazebo/Blue</material>
        <mu1 value="0"/>
        <mu2 value="0"/>
        <slip1>1.0</slip1>
        <slip2>1.0</slip2>
    </gazebo> -->


    <!-- CASTER WHEEL LEFT BEHIND LINK -->

    <joint name="caster_wheel_left_behind_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_left_behind"/>
        <origin xyz="-0.4 0.17 -0.0749" rpy="0 0 0"/>
    </joint>
    
    <link name="caster_wheel_left_behind">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="1" radius="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <!-- <gazebo reference="caster_wheel_left_behind">
        <material>Gazebo/Blue</material>
        <mu1 value="0"/>
        <mu2 value="0"/>
        <slip1>1.0</slip1>
        <slip2>1.0</slip2>
    </gazebo> -->



    <!-- CASTER WHEEL RIGHT FRONT LINK -->

    <joint name="caster_wheel_right_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_right_front"/>
        <origin xyz="0.4 0.17 -0.0749" rpy="0 0 0"/>
    </joint>
    
    <link name="caster_wheel_right_front">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="1" radius="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <!-- <gazebo reference="caster_wheel_right_front">
        <material>Gazebo/Blue</material>
        <mu1 value="0"/>
        <mu2 value="0"/>
        <slip1>1.0</slip1>
        <slip2>1.0</slip2>
    </gazebo> -->



    <!-- CASTER WHEEL LEFT FRONT LINK -->

    <joint name="caster_wheel_left_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_left_front"/>
        <origin xyz="0.4 -0.17 -0.0749" rpy="0 0 0"/>
    </joint>
    
    <link name="caster_wheel_left_front">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="1" radius="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <!-- <gazebo reference="caster_wheel_left_front">
        <material>Gazebo/Blue</material>
        <mu1 value="0"/>
        <mu2 value="0"/>
        <slip1>1.0</slip1>
        <slip2>1.0</slip2>
    </gazebo> -->
    

</robot>